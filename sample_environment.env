# Materials Project access
MP_API_KEY=your_materials_project_api_key
# Optional alternative to MP_API_KEY
# MP_API_KEY_FILE=C:\Users\YourName\.mp_api_key

# DFT-D3 executable
S_DFTD3_CMD=s-dftd3

# Optional runtime tuning
MP_TASK_WORKERS=8
DFTD3_WORKERS=4
DFTD3_TIMEOUT_SECONDS=900
MP_API_SLEEP_SECONDS=0.25
STRAIN_START=-5
STRAIN_STOP=29

# Optional dataset filtering
# PIPELINE_METALS=Sc,Ti,V,Cr,Mn,Fe,Co,Ni,Cu,Zn,Y,Zr,Nb,Mo,Tc,Ru,Rh,Pd,Ag,Cd,Hf,Ta,W,Re,Os,Ir,Pt,Au,Hg
# PIPELINE_LIGANDS=O,S
# ALLOW_IDENTICAL_METAL_PAIRS=false

